<cell id="cell-35"><cell_type>markdown</cell_type>### 实验 5：容器类的 state_dict 命名规则对比</cell id="cell-35">
<cell id="cell-36"># 构建一个包含所有容器类型的模型，对比 state_dict key 命名
class ContainerDemo(nn.Module):
    def __init__(self):
        super().__init__()
        # Sequential 自动编号
        self.backbone = nn.Sequential(
            nn.Linear(64, 32),
            nn.ReLU(),
        )
        # Sequential 命名 key
        self.head = nn.Sequential(OrderedDict([
            ('fc', nn.Linear(32, 16)),
            ('act', nn.ReLU()),
        ]))
        # ModuleList
        self.branches = nn.ModuleList([
            nn.Linear(16, 8),
            nn.Linear(16, 8),
        ])
        # ModuleDict
        self.adapters = nn.ModuleDict({
            'scale': nn.Linear(8, 8),
            'shift': nn.Linear(8, 8),
        })
        # ParameterList
        self.biases = nn.ParameterList([
            nn.Parameter(torch.randn(8)),
            nn.Parameter(torch.randn(8)),
        ])

model = ContainerDemo()

print("=== state_dict key 命名规则 ===\n")
sd = model.state_dict()
for k, v in sd.items():
    print(f"  {k:<40} shape={list(v.shape)}")

print(f"\n=== 规则总结 ===")
print(f"  Sequential (自动编号):  backbone.0.weight, backbone.1 等")
print(f"  Sequential (命名 key):   head.fc.weight, head.act 等")
print(f"  ModuleList:              branches.0.weight, branches.1 等")
print(f"  ModuleDict:              adapters.scale.weight, adapters.shift 等")
print(f"  ParameterList:           biases.0, biases.1（直接参数，无子属性）")</cell id="cell-36">

