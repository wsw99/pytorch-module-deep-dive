<cell id="07-c2-filter-code"># 最佳实践：只加载 shape 匹配的 key
def filter_state_dict(source_sd, target_sd):
    """只保留 shape 匹配的 key"""
    filtered = OrderedDict()
    for k, v in source_sd.items():
        if k in target_sd and target_sd[k].shape == v.shape:
            filtered[k] = v
    return filtered

