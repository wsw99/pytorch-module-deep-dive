  "block1.linear"._parameters = ['weight', 'bias']
  "block1.bn"._parameters = ['weight', 'bias']
  "block2.linear"._parameters = ['weight', 'bias']
  "block2.bn"._parameters = ['weight', 'bias']
  "head"._parameters = ['weight', 'bias']

